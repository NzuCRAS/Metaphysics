# LLM 提供商配置
# 可选：openai | anthropic | openai_compatible
LLM_PROVIDER=openai_compatible
# OPENAI_BASE_URL=

# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# 国产模型兼容层（OpenAI API 格式）
OPENAI_COMPATIBLE_BASE_URL=https://api.deepseek.com
OPENAI_COMPATIBLE_API_KEY=sk-c5805dfdc81c4b9c9843abab2cc0a08a
OPENAI_COMPATIBLE_MODEL=deepseek-v4-pro

# 预留中间件
DB_PASSWORD=metaphysics_pass
DATABASE_URL=postgresql+asyncpg://metaphysics:metaphysics_pass@postgres:5432/metaphysics
REDIS_URL=redis://redis:6379/0

# 应用配置
APP_ENV=production
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:8080","http://127.0.0.1:8080","http://localhost:8000"]

# LLM 成本控制（DeepSeek V4-Pro 折扣价，单位：元 / 1M tokens）
MAX_DAILY_COST_CNY=50.0
INPUT_TOKEN_PRICE_CNY_PER_M=3.0
OUTPUT_TOKEN_PRICE_CNY_PER_M=6.0
LLM_MAX_TOKENS=4096
LLM_TIMEOUT=120
LLM_MAX_RETRIES=2
COST_SAFETY_FACTOR=1.5

# 管理后台：每日流量报告下载
ADMIN_TOKEN=change_me_in_production