# LLM 提供商配置
# 可选：openai | anthropic | openai_compatible
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=

# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# 国产模型兼容层（OpenAI API 格式）
# OPENAI_COMPATIBLE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# OPENAI_COMPATIBLE_API_KEY=
# OPENAI_COMPATIBLE_MODEL=qwen-vl-max

# 预留中间件
DB_PASSWORD=metaphysics_pass
DATABASE_URL=postgresql+asyncpg://metaphysics:metaphysics_pass@postgres:5432/metaphysics
REDIS_URL=redis://redis:6379/0

# 应用配置
APP_ENV=production
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:8080","http://127.0.0.1:8080","http://localhost:8000"]
